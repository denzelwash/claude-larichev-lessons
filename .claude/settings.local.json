{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(powershell *)",
      "Bash(npx tsc *)",
      "Bash(npx nest *)",
      "Bash(echo \"exit: $?\")"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"$(pwd | sed 's|.*/||') | $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'no-git') | $CLAUDE_MODEL\""
  },
  "outputStyle": "default"
}
