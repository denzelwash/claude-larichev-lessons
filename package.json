{
  "name": "claude-larichev-lessons",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w apps/web run dev",
    "dev:api": "npm -w apps/api run start:dev",
    "build:web": "npm -w apps/web run build",
    "build:api": "npm -w apps/api run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "prisma:generate": "npm -w apps/api run prisma:generate",
    "prisma:migrate": "npm -w apps/api run prisma:migrate"
  }
}
