{
  "name": "claude-larichev-lessons",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w apps/frontend run dev",
    "dev:api": "npm -w apps/backend run start:dev",
    "build:web": "npm -w apps/frontend run build",
    "build:api": "npm -w apps/backend run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "prisma:generate": "npm -w apps/backend run prisma:generate",
    "prisma:migrate": "npm -w apps/backend run prisma:migrate",
    "test:api": "npm -w apps/backend run test",
    "test:web": "npm -w apps/frontend run test",
    "test": "npm run test:api && npm run test:web"
  }
}
